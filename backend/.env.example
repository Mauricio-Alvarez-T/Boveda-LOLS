# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=sgdl
DB_PORT=3306
# Tamaño del pool de conexiones MySQL (default 50)
DB_POOL_LIMIT=50

# JWT
JWT_SECRET=tu_clave_secreta_cambiar_en_produccion
JWT_EXPIRES_IN=8h

# Server
PORT=3000

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# ── Rate limiting ──
# Reverse proxy delante de Node. cPanel + Apache + Passenger = 1 hop → TRUST_PROXY=1.
# Alternativas: 'loopback', un nº mayor de hops, o lista CIDR.
# NO usar 'true' (permisivo): express-rate-limit@8 lanza ERR_ERL_PERMISSIVE_TRUST_PROXY.
TRUST_PROXY=1

# Limiter general (cupo POR USUARIO autenticado; cae a IP si no hay token)
RATE_LIMIT_WINDOW_MS=900000     # 15 min
RATE_LIMIT_MAX=1000             # peticiones por usuario por ventana

# Limiter de login (por IP, anti fuerza bruta)
RATE_LIMIT_LOGIN_WINDOW_MS=900000   # 15 min
RATE_LIMIT_LOGIN_MAX=10             # intentos por IP por ventana
